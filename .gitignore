# Virtual environment
.venv/

# Python cache
__pycache__/
*.py[cod]
*.egg-info/
.pytest_cache/

# Raw and generated data
data/raw/*
!data/raw/.gitkeep
!data/interim/.gitkeep
!data/processed/.gitkeep


# Jupyter and IDE
.ipynb_checkpoints/
.vscode/

# Model objects
*.pkl
*.joblib
*.keras
*.h5

# Operating-system files
Thumbs.db
.DS_Store

# Large generated model binaries
outputs/model_objects/*
!outputs/model_objects/.gitkeep